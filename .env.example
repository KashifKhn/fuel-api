# Turso (libSQL) — required in production; omit both for local dev to use ./local.db
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Shared secret for POST /api/admin/refresh (manual scrape trigger)
ADMIN_SECRET=change-me-to-something-random

# Heroku sets this automatically — only needed for local dev if you want a fixed port
PORT=3000
